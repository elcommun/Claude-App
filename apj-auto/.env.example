# APJ発注自動化 設定ファイル
# このファイルを .env にコピーして値を記入する（.env は git 管理外）
#   cp .env.example .env && chmod 600 .env

# ===== GoQ System =====
GOQ_LOGIN_URL=https://order.goqsystem.com/goq21/
GOQ_LIST_URL=https://order.goqsystem.com/goq21/index_beta.php?stat=23&page={page}
GOQ_SHOP_ID=
GOQ_USER_ID=
GOQ_PASSWORD=
# APJ発注書用のCSVダウンロードテンプレート名（GoQ側で作成済みのもの）
GOQ_CSV_TEMPLATE=
# 発注済みステータスの表示名
GOQ_STATUS_DONE=APJ:発注【済】
# デバッグ時 false にするとブラウザ画面が表示される
GOQ_HEADLESS=true

# ===== メール（SMTP・非Google Workspace）=====
# 【要確認】ec@elcommun.co.jp のSMTP接続情報
SMTP_HOST=
SMTP_PORT=587
# 465/SSL を使う場合は SMTP_PORT=465, SMTP_SSL=true
SMTP_SSL=false
SMTP_USER=ec@elcommun.co.jp
SMTP_PASSWORD=

MAIL_FROM=ec@elcommun.co.jp
# 【要確認】APJ 神代様・斎藤様のメールアドレス（カンマ区切り）
MAIL_TO=
# 【要確認】CC の要否
MAIL_CC=
# 社内控え（Sentに残らない場合があるためBCC推奨）
MAIL_BCC=ec@elcommun.co.jp

# ===== 通知・動作 =====
# エラー通知先（省略時は MAIL_FROM 宛）【要確認】
NOTIFY_TO=ec@elcommun.co.jp
# ひとことメモに「YYYY-MM-DD発注」既入力の注文を発注対象から除外する
EXCLUDE_IF_MEMO_ORDERED=true
RETRY_COUNT=3
RETRY_WAIT_SEC=10

# ===== パス =====
# ログ・state・発注書の保存先
APJ_HOME=~/apj-order
